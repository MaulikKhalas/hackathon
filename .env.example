# Get a key from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: PostgreSQL for user-uploaded calls (table `call_records`).
# If unset, metadata stays in data/user-calls.json.
# If the server is down, the app falls back to the JSON file — or comment this out:
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/callaura

# Chat model for call analysis (JSON scores, segments, etc.). Default in code is gpt-4o-mini.
# Use gpt-4o only if your OpenAI project has access.
# OPENAI_ANALYSIS_MODEL=gpt-4o-mini

# Folder containing Call-1.mp3, Call 3.wav, etc. (for /api/recordings/* playback)
# HACKATHON_AUDIO_DIR=
